<div class="box">
 
<h2>Customer Form</h2>

<form id="customerForm">
  <input type="email" id="email" placeholder="Email" required>
  <input type="text" id="name" placeholder="Name" required>
  <input type="text" id="phone" placeholder="Phone">
  <textarea id="address" placeholder="Address"></textarea>
  <input type="text" id="product" placeholder="Product">
  <input type="number" id="qty" placeholder="Qty">

  <button type="submit">Submit</button>
</form>

<p id="msg"></p>

</div>

<script>
  document.getElementById("customerForm").addEventListener("submit", async function(e) {
  e.preventDefault();

  const data = {
    email: document.getElementById("email").value,
    name: document.getElementById("name").value,
    phone: document.getElementById("phone").value,
    address: document.getElementById("address").value,
    product: document.getElementById("product").value,
    qty: document.getElementById("qty").value
  };

  console.log("Sending:", data);

  try {
    const res = await fetch("https://dashcharger.webrootinfosoft.com/form-upload.php", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(data)
    });

    const result = await res.json();

    console.log("Response:", result);

    if (result.status === "success") {
      document.getElementById("msg").innerText = "Data saved successfully ✅";
      document.getElementById("customerForm").reset();
    } else {
      document.getElementById("msg").innerText = "Error: " + result.message;
    }

  } catch (err) {
    console.log("ERROR:", err);
    document.getElementById("msg").innerText = "Something went wrong ❌";
  }
});
</script>

<style>
/* Inputs */
#customerForm input,
#customerForm textarea {
  width: 100%;
  padding: 12px;
  margin: 0 0 10px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
  transition: 0.3s;
}
#customerForm textarea {
  margin: 0;
}
/* Message */
#msg {
  margin-top: 10px;
  text-align: center;
  font-weight: bold;
}

/* Success & Error colors */
#msg.success {
  color: green;
}

#msg.error {
  color: red;
}

/* Responsive */
@media (max-width: 400px) {
  #customerForm {
    width: 90%;
    padding: 20px;
  }
}
</style>
<div class="box">
  <h2>Upload CSV</h2>

  <form id="csvUploadForm">
    <input type="file" id="csvFile" accept=".csv" required>
    <br>
    <button type="submit">Upload</button>
  </form>

  <div id="loader">Uploading...</div>
  <div id="status"></div>
</div>



<script>
document.addEventListener("DOMContentLoaded", function () {

  const form = document.getElementById("csvUploadForm");
  const loader = document.getElementById("loader");
  const status = document.getElementById("status");

  form.addEventListener("submit", async function(e) {
    e.preventDefault();

    const fileInput = document.getElementById("csvFile");

    if (!fileInput.files.length) {
      status.innerText = "Select file first";
      return;
    }

    const formData = new FormData();
    formData.append("file", fileInput.files[0]);

    loader.style.display = "block";
    status.innerText = "";

    try {
      const response = await fetch("https://dashcharger.webrootinfosoft.com/csv-upload.php", {
        method: "POST",
        body: formData
      });

      const text = await response.text();

      let data;
      try {
        data = JSON.parse(text);
      } catch (e) {
        loader.style.display = "none";
        status.innerText = "Server error";
        return;
      }

      loader.style.display = "none";

      if (data.success) {
        status.innerText = "✅ Uploaded: " + data.inserted + " rows";
        fileInput.value = "";

        // 🔥 SEND MESSAGE TO SHOPIFY APP (IMPORTANT)
        window.parent.postMessage(
          { type: "CSV_UPLOADED_SUCCESS" },
          "*"
        );

      } else {
        status.innerText = "❌ " + data.message;
      }

    } catch (err) {
      loader.style.display = "none";
      status.innerText = "Network error";
    }

  });

});
</script>

<style>

.box {
  max-width: 420px;
  margin: 60px auto;
  background: #fff;
  padding: 20px;
  text-align: center;
  border: 1px solid #ddd;
  border-radius: 8px;
}

button {
  background: black;
  color: white;
  padding: 10px 15px;
  border: none;
  margin-top: 10px;
  cursor: pointer;
}

#status { margin-top: 15px; font-weight: bold; }
#loader { display:none; margin-top:10px; }
</style>


{% schema %}
{
  "name": "CSV Upload",
  "target": "section",
  "settings": []
}
{% endschema %}
