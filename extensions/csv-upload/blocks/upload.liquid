<script>
    const productSelect = document.getElementById("productSelect");
const variantSelect = document.getElementById("variantSelect");
const variantBox = document.getElementById("variantBox");

productSelect.addEventListener("change", function () {
  const productId = this.value;

  variantSelect.innerHTML = "";

  const product = shopifyProducts.find(p => p.id === productId);

  if (!product || product.variants.length === 0) {
    variantBox.style.display = "none";
    return;
  }

  variantBox.style.display = "block";

  product.variants.forEach(v => {
    const option = document.createElement("option");
    option.value = v.id;
    option.textContent = v.title;
    variantSelect.appendChild(option);
  });
});
  const shopifyProducts = [
    {% for product in collections.all.products %}
      {
        id: "{{ product.id }}",
        title: "{{ product.title }}",
        variants: [
          {% for variant in product.variants %}
            {
              id: "{{ variant.id }}",
              title: "{{ variant.title }}"
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];
</script>


<script>

   document.addEventListener("DOMContentLoaded", function () {

  const fileInput = document.getElementById("csvFile");
  const selectBtn = document.getElementById("selectFileBtn");

  if (!fileInput || !selectBtn) {
    console.error("File input or button not found");
    return;
  }

  selectBtn.addEventListener("click", function (e) {
    e.preventDefault();
    fileInput.click();
  });

  fileInput.addEventListener("change", function () {
    console.log("File selected:", fileInput.files[0]);
  });

});
document.getElementById("uploadBtn").addEventListener("click", async function () {

  const fileInput = document.getElementById("csvFile");
  const status = document.getElementById("status");
  const loader = document.getElementById("loader");

  if (!fileInput.files.length) {
    alert("Please select CSV file");
    return;
  }

  const file = fileInput.files[0];
  const text = await file.text();

  // ================= FIX: TAB / CSV SUPPORT =================
  const rows = text
    .trim()
    .split("\n")
    .map(r => r.split(/\t|,/));   // ✅ FIXED HERE

  rows.shift(); // remove header

  function isEmpty(v) {
    return !v || v.toString().trim() === "";
  }

  // ================= FETCH SHOPIFY PRODUCTS =================
  let productMap = {};

  try {
    const res = await fetch("/products.json?limit=250");
    const json = await res.json();

    json.products.forEach(p => {
      productMap[p.title.trim().toLowerCase()] = p;
    });

  } catch (err) {
    alert("Failed to load Shopify products");
    return;
  }

  // ================= VALIDATE ROWS =================
  for (let i = 0; i < rows.length; i++) {

    const r = rows[i];

    if (!r || r.length < 15) {
      alert(`Row ${i + 2}: Missing columns`);
      return;
    }

    const [
      partyName,
      partyAddress,
      firstName,
      lastName,
      email,
      phone,
      street,
      city,
      province,
      postal,
      country,
      product,
      v1,
      v2,
      v3,
      qty
    ] = r;

    // ================= REQUIRED CHECK =================
    const errors = [];

    if (isEmpty(partyName)) errors.push("Participating Party Name");
    if (isEmpty(partyAddress)) errors.push("Participating Party Address");
    if (isEmpty(firstName)) errors.push("First Name");
    if (isEmpty(lastName)) errors.push("Last Name");
    if (isEmpty(email)) errors.push("Email Address");
    if (isEmpty(phone)) errors.push("Phone Number");
    if (isEmpty(street)) errors.push("Street Address");
    if (isEmpty(city)) errors.push("City");
    if (isEmpty(province)) errors.push("Province");
    if (isEmpty(postal)) errors.push("Postal Code");
    if (isEmpty(country)) errors.push("Country");
    if (isEmpty(product)) errors.push("Product Name");
    if (isEmpty(qty)) errors.push("Qty");

    if (errors.length > 0) {
      alert(`Row ${i + 2}: Missing → ${errors.join(", ")}`);
      return;
    }

    // ================= PRODUCT CHECK =================
    const productKey = product.trim().toLowerCase();
    const shopifyProduct = productMap[productKey];

    if (!shopifyProduct) {
      alert(`Row ${i + 2}: Product "${product}" not found`);
      return;
    }

    // ================= VARIANT RULE =================
    const optionsCount = shopifyProduct.options.length;

    if (optionsCount >= 1 && isEmpty(v1)) {
      alert(`Row ${i + 2}: Variant 1 required`);
      return;
    }

    if (optionsCount >= 2 && (isEmpty(v1) || isEmpty(v2))) {
      alert(`Row ${i + 2}: Variant 1 & 2 required`);
      return;
    }

    if (optionsCount >= 3 && (isEmpty(v1) || isEmpty(v2) || isEmpty(v3))) {
      alert(`Row ${i + 2}: Variant 1, 2 & 3 required`);
      return;
    }

    // ================= BUILD VARIANT =================
    let csvVariants = [];

    if (!isEmpty(v1)) csvVariants.push(v1.trim());
    if (!isEmpty(v2)) csvVariants.push(v2.trim());
    if (!isEmpty(v3)) csvVariants.push(v3.trim());

    const csvVariantString = csvVariants.join(" / ");

    // ================= SHOPIFY MATCH =================
    const shopifyVariants = shopifyProduct.variants.map(v => v.title.trim());

    const match = shopifyVariants.some(v =>
      v.toLowerCase() === csvVariantString.toLowerCase()
    );

    if (!match) {
      alert(
        `Row ${i + 2}: Variant "${csvVariantString}" not found\nAvailable: ${shopifyVariants.join(", ")}`
      );
      return;
    }

    // ================= QTY FIX =================
    if (isNaN(qty) || Number(qty) < 1) {
      alert(`Row ${i + 2}: Qty must be valid number`);
      return;
    }
  }

  // ================= UPLOAD =================
  const formData = new FormData();
  formData.append("file", file);

  loader.style.display = "block";
  status.innerText = "";

  try {
    const res = await fetch("https://dashcharger.webrootinfosoft.com/csv-upload.php", {
      method: "POST",
      body: formData
    });

    const data = await res.json();

    loader.style.display = "none";
    console.log('data',data)

    if (data.success) {
        const status_text = document.getElementById("status_text");
        console.log('data_main',data)
      status_text.innerText = "✅ Uploaded: " + data.inserted + " rows";
      fileInput.value = "";

    } else {
      status.innerText = "❌ " + data.message;
    }

  } catch (e) {
    loader.style.display = "none";
    status.innerText = "❌ Upload failed";
  }

});
</script>

