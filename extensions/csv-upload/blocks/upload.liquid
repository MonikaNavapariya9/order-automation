<script>
  function switchTab(tab) {
    const singleContainer = document.getElementById('single-form-container');
    const batchContainer = document.getElementById('batch-form-container');
    const singleToggle = document.getElementById('toggle-single');
    const batchToggle = document.getElementById('toggle-batch');

    if (tab === 'single') {
      singleContainer.classList.remove('hidden');
      batchContainer.classList.add('hidden');
      singleToggle.classList.add('bg-surface-container-lowest', 'text-primary', 'shadow-sm');
      singleToggle.classList.remove('text-on-surface-variant');
      batchToggle.classList.remove('bg-surface-container-lowest', 'text-primary', 'shadow-sm');
      batchToggle.classList.add('text-on-surface-variant');
    } else {
      singleContainer.classList.add('hidden');
      batchContainer.classList.remove('hidden');
      batchToggle.classList.add('bg-surface-container-lowest', 'text-primary', 'shadow-sm');
      batchToggle.classList.remove('text-on-surface-variant');
      singleToggle.classList.remove('bg-surface-container-lowest', 'text-primary', 'shadow-sm');
      singleToggle.classList.add('text-on-surface-variant');
    }
  }

document.getElementById("customerButton").addEventListener("click", async function (e) {
  e.preventDefault();

  console.log("BUTTON CLICKED");

  const first_name = document.getElementById("first_name").value.trim();
  if (!first_name) return alert("First Name is required");

  const last_name = document.getElementById("last_name").value.trim();
  if (!last_name) return alert("Last Name is required");

  const email = document.getElementById("email_text").value.trim();
  console.log('email',email,last_name)
